# Redis (same instance as FastAPI / Celery)
REDIS_URL=redis://127.0.0.1:6379/0

# Comma-separated account phone numbers (E.164 digits) assigned to this worker shard
# Example: 989048249523,989121234567
ACCOUNT_IDS=

# Admin API
API_PORT=3000
API_KEY=
LINK_SESSION_TIMEOUT_MS=60000

# PM2 shard account lists (comma-separated E.164 digits per worker)
WPP1_ACCOUNT_IDS=
WPP2_ACCOUNT_IDS=
WPP3_ACCOUNT_IDS=
WPP4_ACCOUNT_IDS=
WPP5_ACCOUNT_IDS=

# Session storage root (relative to whatsapp-service/)
SESSIONS_DIR=sessions

# Proxy config file (relative to whatsapp-service/)
PROXIES_CONFIG=config/proxies.json
# Emergency only — connect without proxy when no mapping exists (default: false)
ALLOW_NO_PROXY_FALLBACK=false

# Logging
LOG_LEVEL=info

# BullMQ names are HARDCODED in queueConfig.js — never use colons (whatsapp_outgoing)
# Legacy OUTGOING_QUEUE / RESULTS_QUEUE env vars are ignored if they contain ":"

# Redis lists for Python integration (colons OK — not BullMQ queue names)
RESULTS_LIST=whatsapp:results
ALERTS_LIST=whatsapp:alerts

# Kill switch keys (either blocks sends)
KILL_SWITCH_KEY=whatsapp:kill_switch
LEGACY_KILL_SWITCH_KEY=system:whatsapp_send_disabled

# Support alerts (401 / session invalid) — first non-empty value wins
TELEGRAM_WEBHOOK_URL=
ADMIN_ALERT_WEBHOOK=

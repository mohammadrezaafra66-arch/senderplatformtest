DATABASE_URL=postgresql://mmp_user:mmp_pass@postgres:5432/mmp_db
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me
SESSION_SECRET=generate-fernet-key-here

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3

PRICING_API_URL=http://192.168.170.10:3000/pricing/amin-hozoor-board
PRICING_API_URL_DEV=http://core_api:8000/debug/mock-pricing/amin-hozoor-board
PRICING_CACHE_TTL_SECONDS=300
PRICING_ENABLE_SCRAPER_FALLBACK=true
PRICING_SCRAPER_MIN_ITEMS=1
PRICING_ENABLE_PLAYWRIGHT_FALLBACK=true
PRICING_PLAYWRIGHT_HEADLESS=true
PRICING_PLAYWRIGHT_TIMEOUT_MS=30000
PRICING_PLAYWRIGHT_PROFILE_DIR=storage/browser_profiles/pricing_scraper
PRICING_PLAYWRIGHT_MAX_PAGES=20
PRICING_PLAYWRIGHT_PAGE_WAIT_MS=1500

# Phase 4 safety gates (defaults must stay dry-run safe)
REAL_QUEUE_PUSH_ENABLED=false
REAL_MESSAGE_SENDING_ENABLED=false
WORKER_EXECUTION_ENABLED=false
CHANNEL_CONNECTORS_ENABLED=false
PHASE_4_DEBUG_MODE=true

# Worker delivery (Phase 8)
DRY_RUN=false
SHADOW_MODE=false
SHADOW_PHONE_NUMBER=
BALE_API_BASE_URL=https://tapi.bale.ai
BALE_API_TIMEOUT_SECONDS=30
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_API_TIMEOUT_SECONDS=30
RUBIKA_API_BASE_URL=https://botapi.rubika.ir/v3
RUBIKA_API_TIMEOUT_SECONDS=30

# روبیکا v2 — ماژول چند اکانتی (سند خرداد ۱۴۰۵). همه گیت‌ها false تا فاز ۲-۸ تکمیل و تست شود.
# bot_api = همان مسیر فعلی (دست‌نخورده) | user_account = rubpy روی اکانت شخصی (جدید)
RUBIKA_DELIVERY_MODE=bot_api
RUBIKA_USER_ACCOUNT_ENABLED=false
RUBIKA_CONVERSATION_MODE_ENABLED=false
RUBIKA_SESSION_DIR=storage/rubika_sessions
RUBIKA_MIN_SEND_DELAY_SECONDS=5
RUBIKA_MAX_SEND_DELAY_SECONDS=15
RUBIKA_HOURLY_SEND_CAP=50
RUBIKA_DAY_PHASE_START_HOUR=8
RUBIKA_DAY_PHASE_END_HOUR=22
# id اکانت عضو pool با phase=listener (پایش گروه‌ها) — باید کاملاً مجزا از اکانت‌های ارسال باشد
RUBIKA_LISTENER_ACCOUNT_ID=0
# id اکانت عضو pool با phase=status (لایک/نظر استاتوس) — باید کاملاً مجزا از ارسال و پایش باشد
RUBIKA_STATUS_ACCOUNT_ID=0
RUBIKA_STATUS_LIKE_DELAY_MIN_SECONDS=5
RUBIKA_STATUS_LIKE_DELAY_MAX_SECONDS=30
RUBIKA_STATUS_HOURLY_LIKE_CAP=30
RUBIKA_STATUS_DAILY_COMMENT_CAP=10

WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0
WHATSAPP_API_TIMEOUT_SECONDS=30
# web = Playwright + QR session (default) | cloud_api = Meta Graph API
WHATSAPP_DELIVERY_MODE=web
WHATSAPP_WEB_PROFILE_ROOT=storage/browser_profiles/whatsapp
WHATSAPP_WEB_HEADLESS=true
WHATSAPP_WEB_SEND_TIMEOUT_SECONDS=90

# WhatsApp worker pool (WA-4) — scale with:
# docker compose up -d --scale whatsapp_worker_pool=3
# Set WORKER_POOL_SIZE to the same number as replicas when using auto sharding.
WHATSAPP_ACCOUNT_IDS=248
WORKER_POOL_SIZE=1
WORKER_POOL_INDEX=-1
WHATSAPP_POOL_BROWSER_LOCK=true

# WA-5 — retry, rate limit, distributed lock, heartbeat
WHATSAPP_MAX_RETRY_ATTEMPTS=3
WHATSAPP_RETRY_BASE_DELAY_SECONDS=5
WHATSAPP_MIN_SEND_DELAY_SECONDS=3
WHATSAPP_HOURLY_SEND_CAP=100
WHATSAPP_DISTRIBUTED_LOCK_ENABLED=true
WHATSAPP_DISTRIBUTED_LOCK_TTL_SECONDS=120
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_TTL_SECONDS=45

# Phase 9.1 — E2E queue push + worker delivery
# REAL_QUEUE_PUSH_ENABLED=true
# REAL_MESSAGE_SENDING_ENABLED=true
# CHANNEL_CONNECTORS_ENABLED=true
# DRY_RUN=false

# Phase 9.2 — live operational test send via API (triple gate; default OFF)
# Enable only when intentionally sending a real test message:
# OPS_LIVE_SEND_API_ENABLED=true
# REAL_MESSAGE_SENDING_ENABLED=true
# CHANNEL_CONNECTORS_ENABLED=true
# DRY_RUN=false
OPS_LIVE_SEND_API_ENABLED=false
# Route WhatsApp Web live API test sends to Redis queue (use with scripts/whatsapp_worker_pool_windows.ps1)
# WHATSAPP_OPS_SEND_VIA_WORKER_QUEUE=true

# Windows host QR link mini-API for in-UI WhatsApp Web QR (start_platform.ps1)
WHATSAPP_QR_LINK_URL=http://host.docker.internal:8765

# Baileys whatsapp-service mini-API (link-session, warmup trigger proxy)
WHATSAPP_SERVICE_URL=http://localhost:3000
WHATSAPP_SERVICE_API_KEY=

# Emergency stop — blocks ALL WhatsApp Web sends (set true + restart workers/core_api)
# WHATSAPP_SENDING_DISABLED=true
# Runtime toggle without restart: scripts/whatsapp_send_kill_switch.ps1 -Enable

# Phase 0 — Evolution API infrastructure (sidecar; WHATSAPP_DELIVERY_MODE stays "web" until cutover)
EVOLUTION_API_KEY=change-me-generate-secure-api-key
EVOLUTION_API_URL=http://evolution_api:8080
EVOLUTION_WEBHOOK_URL=http://core_api:8000/webhooks/whatsapp/evolution
EVOLUTION_WEBHOOK_SECRET=change-me-webhook-hmac-secret
WHATSAPP_EVOLUTION_SEND_TIMEOUT=30
# Safety gate — هرگز در production false نشود. بدون proxy ثابت per-instance،
# instance ساخته نمی‌شود (پیاده‌سازی در فاز ۲).
WHATSAPP_EVOLUTION_REQUIRE_PROXY=true

# Proxy sticky test (scripts/test_proxy_sticky.sh at repo root — fill only for manual pilot tests)
# PROXY_TEST_HOST=
# PROXY_TEST_PORT=
# PROXY_TEST_USER=
# PROXY_TEST_PASS=
# PROXY_TEST_PROTOCOL=http

# Evolution Phase 0 manual test (scripts/evolution_phase0_manual_test.sh)
# EVOLUTION_TEST_INSTANCE_NAME=pilot-account-248
# EVOLUTION_TEST_RECIPIENT=989121234567
# EVOLUTION_TEST_MESSAGE=Phase 0 Evolution API manual test
